{
  "name": "@haoref-boti/pikud-haoref-bot-server",
  "version": "0.4.4",
  "private": true,
  "license": "Apache-2.0",
  "description": "בוט טלגרם להתראות פיקוד העורף בזמן אמת עם מפות Mapbox",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json && npm run build:dashboard",
    "dev": "tsx watch src/index.ts",
    "test": "DB_PATH=:memory: tsx --test src/__tests__/*.test.ts",
    "build:dashboard": "cd dashboard-ui && npm ci && npm run build",
    "dev:dashboard": "cd dashboard-ui && npm run dev"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.0",
    "@turf/bbox": "^7.2.0",
    "@turf/helpers": "^7.2.0",
    "@turf/simplify": "^7.2.0",
    "@turf/union": "^7.3.4",
    "axios": "^1.9.0",
    "better-sqlite3": "^12.8.0",
    "bidi-js": "^1.0.3",
    "chalk": "^4.1.2",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "grammy": "^1.36.0",
    "pikud-haoref-api": "^5.0.3",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
