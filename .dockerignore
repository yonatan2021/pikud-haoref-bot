# Dependencies (rebuilt in builder stage)
node_modules/

# Build output (regenerated by tsc in builder stage)
dist/

# Runtime database (mounted as volume)
data/

# Environment secrets
.env
*.env.*

# Git history
.git/
.gitignore

# Test files (not needed in production image)
src/__tests__/

# Documentation
docs/
README.md

# Claude Code files
.claude*
CLAUDE.md

# Manual test script
test-alert.ts

# macOS metadata
.DS_Store

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# WhatsApp Sessions and Cache (CRITICAL: Prevents leaking session into Docker image)
.wwebjs_auth/
.wwebjs_cache/

# Local databases (should be in data/ but just in case)
*.db
*.db-shm
*.db-wal

# Build artifacts and tools
coverage/
*.tsbuildinfo
.worktrees/
.worktree/
.superpowers/
